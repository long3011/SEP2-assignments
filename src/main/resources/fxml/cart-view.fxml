<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="root" spacing="12" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="shoppingcart.ShoppingCartController">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <HBox spacing="8">
        <Label fx:id="languageLabel" text="Language" minWidth="160"/>
        <ComboBox fx:id="languageComboBox" onAction="#onLanguageChanged" prefWidth="160"/>
    </HBox>

    <HBox spacing="8">
        <Label fx:id="itemCountLabel" text="Item count" minWidth="160"/>
        <TextField fx:id="itemCountField" promptText="How many items?" prefWidth="120"/>
        <Button fx:id="generateRowsButton" text="Generate rows" onAction="#onGenerateRows"/>
    </HBox>

    <ScrollPane fitToWidth="true" prefHeight="300">
        <content>
            <VBox fx:id="itemsContainer" spacing="8"/>
        </content>
    </ScrollPane>

    <HBox spacing="8">
        <Button fx:id="calculateButton" text="Calculate" onAction="#onCalculateTotal"/>
        <Label fx:id="overallTotalTitleLabel" text="Overall total" minWidth="160"/>
        <Label fx:id="overallTotalValueLabel" text="0.00"/>
    </HBox>

    <Label fx:id="statusLabel" style="-fx-text-fill: #b00020;"/>
</VBox>

